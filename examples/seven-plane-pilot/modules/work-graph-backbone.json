  "context": "Cross-plane work-graph backbone connecting business intent, controlled execution, and durable assets across the seven-plane operating system.",
  "sections": [
    {
      "sid": "backbone-chain",
      "topic": "canonical object chain",
      "content": "Chain = Workspace -> ProjectLine -> Project -> Objective -> WorkOrder -> Session -> Run -> Event -> Artifact|MemoryRecord|KnowledgeRecord|AttentionItem|ApprovalRequest. Backbone connects business intent to execution and durable assets. Backbone does not replace planes.",
      "content_type": "rules",
      "refs": [
        "portfolio-project-plane:plane-role",
        "control-plane:plane-role",
        "knowledge-resources-plane:plane-role",
        "governance-spine:spine-role"
      ],
      "artifact_refs": [
        "object-chain"
      ],
      "criticality": "must"
    },
    {
      "sid": "backbone-boundaries",
      "topic": "backbone boundaries",
      "content": "Use backbone to connect planes. Do not collapse Portfolio Project Plane into generic workflow plumbing. Do not treat Work Graph as eighth business plane.",
      "content_type": "rules",
      "refs": [],
      "criticality": "should"
    }
  ],
