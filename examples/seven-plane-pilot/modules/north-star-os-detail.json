  "context": "Canonical operating model for the seven-plane agent operating system. Holds plane roster, resource posture, and backbone distinctions.",
  "sections": [
    {
      "sid": "operating-model",
      "topic": "operating model boundaries",
      "content": "System is multi-entry multi-runtime multi-business-line agent operating system. System is not super-chatbot, not single orchestrator, not undifferentiated memory store. Seven planes stay distinct. Governance Spine cuts across all planes. Work Graph connects planes without replacing planes.",
      "content_type": "rules",
      "refs": [],
      "criticality": "must"
    },
    {
      "sid": "plane-roster",
      "topic": "canonical plane roster",
      "content": "Plane roster = experience-plane|gateway-plane|control-plane|harness-runtime-plane|agent-capability-plane|portfolio-project-plane|knowledge-resources-plane|governance-spine. Load work-graph-backbone for cross-plane object chain. Load target plane module only after task scope is classified.",
      "content_type": "rules",
      "refs": [
        "experience-plane:plane-role",
        "gateway-plane:plane-role",
        "control-plane:plane-role",
        "harness-runtime-plane:plane-role",
        "agent-capability-plane:plane-role",
        "portfolio-project-plane:plane-role",
        "knowledge-resources-plane:plane-role",
        "governance-spine:spine-role",
        "work-graph-backbone:backbone-chain"
      ],
      "artifact_refs": [
        "plane-roster-table",
        "plane-topology"
      ],
      "criticality": "must"
    },
    {
      "sid": "resource-posture",
      "topic": "resource posture snapshot",
      "content": "Admitted seeds = agent-hub -> control-plane; knowledge/ -> knowledge-resources-plane. Provisional candidate = terminal-control-plane -> harness-runtime-plane. Supporting signal producer = harness-doctor -> control-plane. Adjacent bridge candidate = openclaw -> experience-plane|gateway-plane|harness-runtime-plane. Exploratory only = x402-gateway.",
      "content_type": "rules",
      "refs": [
        "control-plane:current-posture",
        "harness-runtime-plane:current-posture",
        "knowledge-resources-plane:current-posture"
      ],
      "criticality": "must"
    }
  ],
