  "artifacts": [
    {
      "artifact_id": "gate-flow",
      "type": "process-flow",
      "usage": "Canonical flow for governed changes crossing plane boundaries or shared truth surfaces.",
      "content": {
        "entry": "propose-change",
        "actors": [
          "governor",
          "reviewer"
        ],
        "terminals": [
          "authorized",
          "held"
        ],
        "steps": [
          {
            "id": "propose-change",
            "type": "action",
            "actor": "governor",
            "action": "record proposed change, touched planes, and intended authority surface",
            "next": "classify-scope"
          },
          {
            "id": "classify-scope",
            "type": "decision",
            "actor": "governor",
            "action": "shared truth or cross-plane boundary touched?",
            "next": {
              "yes": "prepare-packet",
              "no": "authorize-change"
            }
          },
          {
            "id": "prepare-packet",
            "type": "action",
            "actor": "governor",
            "action": "prepare delegation packet, evidence, touched paths, and acceptance criteria",
            "next": "review-evidence"
          },
          {
            "id": "review-evidence",
            "type": "action",
            "actor": "reviewer",
            "action": "inspect evidence, overlap, and authority boundary fit",
            "next": "adjudicate"
          },
          {
            "id": "adjudicate",
            "type": "decision",
            "actor": "reviewer",
            "action": "evidence sufficient and boundary-safe?",
            "next": {
              "yes": "authorize-change",
              "no": "hold-change"
            }
          },
          {
            "id": "authorize-change",
            "type": "action",
            "actor": "governor",
            "action": "record approval and permit implementation",
            "next": "authorized"
          },
          {
            "id": "hold-change",
            "type": "action",
            "actor": "governor",
            "action": "record hold and required follow-up evidence",
            "next": "held"
          },
          {
            "id": "authorized",
            "type": "action",
            "actor": "governor",
            "action": "change authorized",
            "next": null
          },
          {
            "id": "held",
            "type": "action",
            "actor": "governor",
            "action": "change held",
            "next": null
          }
        ]
      }
    }
  ],
