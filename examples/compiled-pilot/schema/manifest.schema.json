{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aods://schema/manifest/v3",
  "title": "AODS Manifest v3",
  "description": "Agent-Optimized Documentation System - root manifest. Entry point for zero-knowledge bootstrap. Adds layer-aware routing and cross-surface pairing.",
  "type": "object",
  "required": [
    "aods_v",
    "sys",
    "created",
    "updated",
    "modules",
    "boot_sequence"
  ],
  "additionalProperties": false,
  "properties": {
    "aods_v": {
      "type": "integer",
      "const": 3,
      "description": "AODS schema version. Breaking changes increment this."
    },
    "sys": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$",
      "description": "System identifier. Globally unique slug for this documentation corpus."
    },
    "sys_v": {
      "type": "integer",
      "minimum": 1,
      "description": "System version. Incremented when any module changes."
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "purpose": {
      "type": "string",
      "maxLength": 300,
      "description": "One-line system purpose. Agent uses this to confirm it has the right corpus."
    },
    "project_topology": {
      "$ref": "#/definitions/project_topology_ref",
      "description": "Optional root topology summary that links the design corpus to one or more implementation repositories."
    },
    "companion_index": {
      "$ref": "#/definitions/relative_path",
      "description": "Optional path to a second-hop manifest companion. Use to externalize glossary, roles, touch routes, and paired-surface maps so manifest.json stays small at bootstrap."
    },
    "glossary": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "maxLength": 200
      },
      "description": "System-wide term definitions. Keys are canonical term IDs used across all modules."
    },
    "roles": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/role_def"
      },
      "description": "All agent roles in the system. Each role maps to a set of modules it must load."
    },
    "modules": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/module_ref"
      },
      "minItems": 1,
      "description": "Registry of all knowledge modules in this corpus."
    },
    "boot_sequence": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Ordered list of module IDs for cold-start bootstrap. Should start with root-layer modules; capsule modules may follow."
    },
    "boot_by_role": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "description": "Role-specific boot sequences. Key is role ID; value is ordered module ID list."
    },
    "boot_by_touch": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/touch_route"
      },
      "description": "Touch-specific progressive-disclosure routes. Each route maps one relative path glob to the minimal module set needed for that edit context."
    },
    "surface_pairs": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/surface_pair"
      },
      "description": "Cross-surface pairing map. Links agent-primary modules to human-facing surfaces outside module registry."
    }
  },
  "definitions": {
    "relative_path": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+",
      "description": "Corpus-contained relative path only. Absolute paths and parent traversal forbidden."
    },
    "role_def": {
      "type": "object",
      "required": [
        "id",
        "scope"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]{1,48}$"
        },
        "scope": {
          "type": "string",
          "maxLength": 200,
          "description": "Natural language scope description."
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "module_ref": {
      "type": "object",
      "required": [
        "id",
        "path",
        "scope",
        "category",
        "layer"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]{1,64}$",
          "description": "Unique module identifier."
        },
        "path": {
          "$ref": "#/definitions/relative_path"
        },
        "scope": {
          "type": "string",
          "maxLength": 300,
          "description": "Semantic coverage description for routing."
        },
        "category": {
          "type": "string",
          "enum": [
            "architecture",
            "protocol",
            "schema",
            "workflow",
            "policy",
            "config",
            "reference",
            "artifact",
            "capsule"
          ],
          "description": "Module classification. capsule = short routing module with compact summary and next hops."
        },
        "layer": {
          "type": "string",
          "enum": [
            "root",
            "capsule",
            "detail",
            "evidence"
          ],
          "description": "Progressive-disclosure tier. root = boot/routing. capsule = summary/route fanout. detail = semantic authority. evidence = proof or draft."
        },
        "deps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tokens_approx": {
          "type": "integer",
          "minimum": 0,
          "description": "Approximate token count for context budget planning."
        },
        "priority": {
          "type": "string",
          "enum": [
            "critical",
            "standard",
            "supplementary"
          ],
          "default": "standard"
        },
        "control": {
          "$ref": "#/definitions/control_meta",
          "description": "Optional control taxonomy for this module. Mirrors module.meta.control when declared."
        },
        "provenance": {
          "$ref": "#/definitions/provenance_ref",
          "description": "Optional provenance summary for bootstrap routing. Mirrors the memory_role and confidence fields from module.meta.provenance."
        },
        "runtime_contract": {
          "$ref": "#/definitions/runtime_contract_ref",
          "description": "Optional runtime contract summary for bootstrap risk and output awareness. Mirrors side_effects and outputs from module.meta.runtime_contract."
        },
        "redaction": {
          "$ref": "#/definitions/redaction_ref",
          "description": "Optional redaction summary for bootstrap risk awareness. Mirrors module.meta.redaction summary fields."
        },
        "contract": {
          "$ref": "#/definitions/contract_ref",
          "description": "Optional contract profile summary. Mirrors module.meta.contract summary fields."
        },
        "schema_versioning": {
          "$ref": "#/definitions/schema_versioning_ref",
          "description": "Optional stable compatibility summary. Mirrors module.meta.schema_versioning summary fields."
        },
        "implementation": {
          "$ref": "#/definitions/implementation_ref",
          "description": "Optional implementation linkage summary. Mirrors module.meta.implementation summary fields."
        }
      }
    },
    "topology_status": {
      "type": "string",
      "enum": [
        "not-started",
        "planned",
        "in-progress",
        "partial",
        "current",
        "blocked",
        "deprecated",
        "removed"
      ]
    },
    "topology_repo_ref": {
      "type": "object",
      "required": [
        "id",
        "locator",
        "role",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]{1,64}$"
        },
        "locator": {
          "type": "string",
          "maxLength": 200,
          "description": "Repository locator, slug, or URL-like identifier."
        },
        "role": {
          "type": "string",
          "pattern": "^[a-z0-9_-]{1,48}$"
        },
        "branch": {
          "type": "string",
          "maxLength": 120
        },
        "status": {
          "$ref": "#/definitions/topology_status"
        },
        "notes": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "project_topology_ref": {
      "type": "object",
      "required": [
        "design_repo",
        "implementation_repos"
      ],
      "additionalProperties": false,
      "properties": {
        "design_repo": {
          "$ref": "#/definitions/topology_repo_ref"
        },
        "implementation_repos": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/topology_repo_ref"
          }
        },
        "topology_type": {
          "type": "string",
          "enum": [
            "mono-repo",
            "multi-repo",
            "hybrid"
          ]
        },
        "status": {
          "$ref": "#/definitions/topology_status"
        },
        "notes": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "implementation_ref": {
      "type": "object",
      "required": [
        "repo_id",
        "paths",
        "status",
        "authority_surface"
      ],
      "additionalProperties": false,
      "properties": {
        "repo_id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]{1,64}$",
          "description": "ID of the linked implementation repository. Must match manifest.project_topology.implementation_repos[].id."
        },
        "paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/definitions/relative_path"
          },
          "description": "Implementation-relative files or directories that carry the module's current implementation."
        },
        "status": {
          "$ref": "#/definitions/topology_status",
          "description": "Implementation posture for the linked repo/path set."
        },
        "pr_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "maxLength": 120
          },
          "description": "Optional PR, issue, or change references that support the linkage claim."
        },
        "authority_surface": {
          "type": "string",
          "maxLength": 160,
          "description": "Module section or artifact ref that owns the linkage claim."
        }
      }
    },
    "control_role": {
      "type": "string",
      "enum": [
        "guide",
        "sensor",
        "hybrid"
      ]
    },
    "control_method": {
      "type": "string",
      "enum": [
        "computational",
        "inferential",
        "hybrid"
      ]
    },
    "control_timing": {
      "type": "string",
      "enum": [
        "pre-commit",
        "ci",
        "continuous",
        "runtime"
      ]
    },
    "control_meta": {
      "type": "object",
      "required": [
        "role",
        "method",
        "timing"
      ],
      "additionalProperties": false,
      "properties": {
        "role": {
          "$ref": "#/definitions/control_role",
          "description": "guide=orient or route. sensor=verify, detect, block, or audit. hybrid=both."
        },
        "method": {
          "$ref": "#/definitions/control_method",
          "description": "computational=deterministic rule or exact algorithm. inferential=heuristic or model-mediated judgment. hybrid=both."
        },
        "timing": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/definitions/control_timing"
          },
          "description": "Phases where this control is expected to act."
        }
      }
    },
    "memory_role": {
      "type": "string",
      "enum": [
        "authority",
        "working",
        "evidence"
      ]
    },
    "confidence_level": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "mixed"
      ]
    },
    "provenance_ref": {
      "type": "object",
      "required": [
        "memory_role",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "memory_role": {
          "$ref": "#/definitions/memory_role",
          "description": "authority=canonical semantic source. working=task-time routing or scratch guidance. evidence=proof-bearing or audit material."
        },
        "confidence": {
          "$ref": "#/definitions/confidence_level",
          "description": "Confidence posture of the module's claims after synthesis and review."
        }
      }
    },
    "runtime_contract_ref": {
      "type": "object",
      "required": [
        "side_effects"
      ],
      "additionalProperties": false,
      "properties": {
        "side_effects": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          },
          "description": "Externally visible effects or durable state transitions. Use ['none'] for read-only behavior."
        },
        "outputs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          },
          "description": "Named durable outputs expected from this module's governed execution path."
        }
      }
    },
    "redaction_ref": {
      "type": "object",
      "required": [
        "has_sensitive_payloads",
        "redaction_posture"
      ],
      "additionalProperties": false,
      "properties": {
        "has_sensitive_payloads": {
          "type": "boolean"
        },
        "redaction_posture": {
          "type": "string",
          "enum": [
            "none",
            "omit",
            "redact",
            "handle-only",
            "debug-only"
          ]
        }
      }
    },
    "contract_ref": {
      "type": "object",
      "required": [
        "profile"
      ],
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "string",
          "enum": [
            "read-model",
            "command",
            "implementation-linkage"
          ]
        }
      }
    },
    "schema_versioning_ref": {
      "type": "object",
      "required": [
        "breaking_policy"
      ],
      "additionalProperties": false,
      "properties": {
        "breaking_policy": {
          "type": "string",
          "enum": [
            "strict",
            "versioned",
            "experimental"
          ]
        }
      }
    },
    "touch_route": {
      "type": "object",
      "required": [
        "match",
        "load_modules"
      ],
      "additionalProperties": false,
      "properties": {
        "match": {
          "$ref": "#/definitions/relative_path",
          "description": "Relative path or glob. Used for authoring-time routing."
        },
        "intent": {
          "type": "string",
          "enum": [
            "any",
            "read",
            "write",
            "validate",
            "sync"
          ],
          "default": "any"
        },
        "load_modules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "reason": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "surface_pair": {
      "type": "object",
      "required": [
        "pair_id",
        "scope",
        "agent_primary",
        "human_primary",
        "sync_source",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "pair_id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]{1,64}$"
        },
        "scope": {
          "type": "string",
          "enum": [
            "system",
            "phase",
            "feature",
            "module"
          ]
        },
        "agent_primary": {
          "type": "string",
          "description": "Primary agent module ID."
        },
        "agent_supporting": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_primary": {
          "$ref": "#/definitions/relative_path"
        },
        "human_supporting": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/relative_path"
          }
        },
        "human_generation": {
          "$ref": "#/definitions/human_generation"
        },
        "sync_source": {
          "type": "string",
          "enum": [
            "agent-primary",
            "human-primary",
            "bidirectional"
          ],
          "description": "Declared update direction. bidirectional remains experimental until merge/conflict protocol is specified."
        },
        "status": {
          "type": "string",
          "enum": [
            "paired",
            "draft",
            "deprecated"
          ]
        },
        "shared_invariants": {
          "type": "array",
          "description": "Exact semantic anchors that must remain present in both agent_primary and human_primary texts for this pair. Use for high-risk facts where paired-surface drift must be rejected objectively.",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          }
        }
      }
    },
    "human_generation_mode": {
      "type": "string",
      "enum": [
        "deterministic"
      ]
    },
    "human_generation_profile": {
      "type": "string",
      "enum": [
        "overview",
        "checklist"
      ]
    },
    "human_generation": {
      "type": "object",
      "required": [
        "mode",
        "profile"
      ],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/definitions/human_generation_mode"
        },
        "profile": {
          "$ref": "#/definitions/human_generation_profile"
        },
        "title": {
          "type": "string",
          "maxLength": 120
        }
      }
    }
  }
}
