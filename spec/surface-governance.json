      }
    },
    {
      "artifact_id": "pair-sync-flow",
      "type": "process-flow",
      "usage": "Canonical update order for paired agent and human surfaces.",
      "content": {
        "entry": "detect-change",
        "actors": [
          "agent",
          "validator"
        ],
        "terminals": [
          "done"
        ],
        "steps": [
          {
            "id": "detect-change",
            "type": "action",
            "actor": "agent",
            "action": "detect semantic or routing change",
            "next": "check-pair"
          },
          {
            "id": "check-pair",
            "type": "decision",
            "actor": "agent",
            "action": "paired surface exists?",
            "next": {
              "yes": "update-agent-primary",
              "no": "done"
            }
          },
          {
            "id": "update-agent-primary",
            "type": "action",
            "actor": "agent",
            "action": "update agent-primary module first; manifest metadata alone does not satisfy agent-primary sync",
            "next": "sync-direction"
          },
          {
            "id": "sync-direction",
            "type": "decision",
            "actor": "agent",
            "action": "sync_source == agent-primary?",
            "next": {
              "yes": "update-human",
              "no": "validate-pair"
            }
          },
          {
            "id": "update-human",
            "type": "action",
            "actor": "agent",
            "action": "update paired human surface after agent semantic source is current",
            "next": "validate-pair"
          },
          {
            "id": "validate-pair",
            "type": "action",
            "actor": "validator",
            "action": "check pair paths, refs, and authority invariants",
            "next": "done"
          },
          {
            "id": "done",
            "type": "action",
            "actor": "agent",
            "action": "pair synchronized",
            "next": null
          }
        ]
      }
    },
    {
