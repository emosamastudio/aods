  "purpose": "AODS v3 self-referential specification. Adds dual-surface pairing, layer-aware progressive disclosure, capsule modules, and structured governance patterns without introducing new artifact classes.",
  "glossary": {
    "aods": "Agent-Optimized Documentation System — format and conventions for agent-first documentation",
    "aop": "Agent-Optimized Prose — writing style maximizing information density per token",
    "module": "Self-contained knowledge unit; one JSON file; loaded atomically into agent context",
    "section": "Subdivision within module; has unique sid; smallest addressable knowledge unit",
    "artifact": "Typed resource embedded in module: structured artifact, generic artifact, or raw payload",
    "manifest": "Root index file; agent reads first to discover corpus structure",
    "cold-start": "Agent bootstrap from zero prior knowledge",
    "warm-restart": "Agent resume with cached knowledge from prior session",
    "sid": "Section identifier; unique within module; used for cross-referencing",
    "corpus": "Complete set of AODS files constituting one system's documentation",
    "context-budget": "Token allocation agent reserves for documentation vs. task processing",
    "surface-pair": "Declared link between agent-primary modules and human-facing surfaces",
    "layer": "Progressive-disclosure load tier: root, capsule, detail, or evidence",
    "capsule": "Short routing module summarizing one slice and pointing toward deeper authority modules"
  },
  "roles": [
