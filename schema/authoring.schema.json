{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aods://schema/authoring/v1",
  "title": "AODS Compiled Authoring Source v1",
  "description": "Concise authoring source compiled into an AODS corpus.",
  "type": "object",
  "required": [
    "authoring_v",
    "corpus",
    "modules"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "authoring_v": {
      "type": "integer",
      "const": 1
    },
    "corpus": {
      "$ref": "#/definitions/corpus_meta"
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/file_output"
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/authoring_module"
      }
    },
    "boot": {
      "$ref": "#/definitions/authoring_boot"
    },
    "surface_pairs": {
      "type": "array",
      "items": {
        "$ref": "aods://schema/manifest/v3#/definitions/surface_pair"
      }
    }
  },
  "definitions": {
    "relative_path": {
      "$ref": "aods://schema/manifest/v3#/definitions/relative_path"
    },
    "corpus_meta": {
      "type": "object",
      "required": [
        "sys"
      ],
      "additionalProperties": false,
      "properties": {
        "sys": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
        },
        "sys_v": {
          "type": "integer",
          "minimum": 1
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        },
        "purpose": {
          "type": "string",
          "maxLength": 300
        },
        "glossary": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "maxLength": 200
          }
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "aods://schema/manifest/v3#/definitions/role_def"
          }
        }
      }
    },
    "file_output": {
      "type": "object",
      "required": [
        "path"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/definitions/relative_path"
        },
        "content": {
          "type": "string"
        },
        "source_path": {
          "$ref": "#/definitions/relative_path"
        }
      },
      "oneOf": [
        {
          "required": [
            "content"
          ]
        },
        {
          "required": [
            "source_path"
          ]
        }
      ]
    },
    "authoring_boot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sequence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "by_role": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "by_touch": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/authoring_touch_route"
          }
        }
      }
    },
    "authoring_touch_route": {
      "type": "object",
      "required": [
        "match"
      ],
      "additionalProperties": false,
      "properties": {
        "match": {
          "$ref": "#/definitions/relative_path"
        },
        "intent": {
          "type": "string",
          "enum": [
            "any",
            "read",
            "write",
            "validate",
            "sync"
          ]
        },
        "load_modules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "load": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string",
          "maxLength": 200
        }
      },
      "oneOf": [
        {
          "required": [
            "load_modules"
          ]
        },
        {
          "required": [
            "load"
          ]
        }
      ]
    },
    "capsule_meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "read_when": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "core_question": {
          "type": "string",
          "maxLength": 240
        },
        "routes_to": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "frozen_decisions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "authoring_module": {
      "type": "object",
      "required": [
        "id",
        "category",
        "layer",
        "scope"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]{1,64}$"
        },
        "path": {
          "$ref": "#/definitions/relative_path"
        },
        "category": {
          "type": "string",
          "enum": [
            "architecture",
            "protocol",
            "schema",
            "workflow",
            "policy",
            "config",
            "reference",
            "artifact",
            "capsule"
          ]
        },
        "layer": {
          "type": "string",
          "enum": [
            "root",
            "capsule",
            "detail",
            "evidence"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "critical",
            "standard",
            "supplementary"
          ]
        },
        "scope": {
          "type": "string",
          "maxLength": 300
        },
        "context": {
          "type": "string",
          "maxLength": 500
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "boot": {
          "type": "boolean"
        },
        "sections": {
          "type": "array",
          "minItems": 1,
          "description": "Optional when the module is artifact-first and the authority lives in typed artifacts.",
          "items": {
            "$ref": "aods://schema/module/v3#/definitions/section"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifacts": {
          "type": "array",
          "description": "Typed artifacts. May be the primary authority surface when the module is artifact-first.",
          "items": {
            "$ref": "aods://schema/module/v3#/definitions/artifact"
          }
        },
        "changelog": {
          "type": "array",
          "items": {
            "$ref": "aods://schema/module/v3#/definitions/changelog_entry"
          }
        },
        "meta": {
          "$ref": "aods://schema/module/v3#/definitions/module_meta"
        },
        "capsule": {
          "$ref": "#/definitions/capsule_meta"
        }
      },
      "anyOf": [
        {
          "required": [
            "sections"
          ]
        },
        {
          "required": [
            "artifacts"
          ]
        }
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "category": {
                "const": "capsule"
              }
            }
          },
          "then": {
            "properties": {
              "layer": {
                "const": "capsule"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "layer": {
                "const": "capsule"
              }
            }
          },
          "then": {
            "properties": {
              "category": {
                "const": "capsule"
              }
            }
          }
        }
      ]
    }
  }
}
