{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aods.dev/schema/conformance-manifest.schema.json",
  "title": "AODS Conformance Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "aods_conformance_manifest_v",
    "suite_id",
    "cases"
  ],
  "properties": {
    "aods_conformance_manifest_v": {
      "const": 0
    },
    "suite_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "target",
          "expected"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": [
              "fixture-smoke",
              "validate"
            ]
          },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "strict": {
                "type": "boolean"
              },
              "reality": {
                "type": "boolean"
              }
            }
          },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "enum": [
                  "pass",
                  "fail",
                  "warn"
                ]
              },
              "rules": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              }
            }
          }
        }
      }
    }
  }
}
